# ============================================================================
#  GL-MT5000 (Brume 3) — MediaTek MT7987A / mediatek-filogic / aarch64
#  MINIMAL DSA-driver validation build.
#  Base: official OpenWrt 25.12 (kernel 6.12), official feeds only.
#  Seed .config — expanded by `make defconfig`. No external feeds, no proxy
#  stack, no themes — just enough to boot and validate the RTL8371C DSA switch.
# ============================================================================

# ---- Target / device ----
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_glinet_gl-mt5000=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
# Also emit an initramfs (RAM-boot) kernel for safe U-Boot/serial testing
# without committing to flash.
CONFIG_TARGET_ROOTFS_INITRAMFS=y

# ---- Build acceleration ----
CONFIG_DEVEL=y
CONFIG_CCACHE=y

# ---- The reason this build exists: RTL8371C/RTL8366UB DSA switch driver ----
CONFIG_PACKAGE_kmod-rtl8366ub=y

# ---- Web UI (optional, handy for validation) ----
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl-openssl=y

# ---- Switch / DSA validation tools ----
CONFIG_PACKAGE_ethtool=y        # link speed / port state
CONFIG_PACKAGE_ip-full=y        # `ip -d link` DSA/bridge inspection
CONFIG_PACKAGE_tcpdump=y        # verify tagged frames on the trunk

# Base OpenWrt already provides dnsmasq, firewall4, dropbear (SSH), netifd,
# DSA core, and the mt76/mtk-eth drivers via the target defaults.
